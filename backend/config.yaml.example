db:
  host: localhost
  port: 3306
  user: cet_agent
  password: your_password_here
  name: cet_web_agent

model:
  base_url: https://api.openai.com/v1
  api_key: your_api_key_here
  model: gpt-4o-mini

session:
  secret_key: change_this_to_a_random_string
  cookie_secure: false  # set to true in production (HTTPS)

cors:
  allowed_origins:
    - http://localhost:8080
    - http://127.0.0.1:8080
